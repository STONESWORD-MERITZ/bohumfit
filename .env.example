# Backend (Railway)
GOOGLE_API_KEY=
CORS_ORIGINS=https://bohumfit.ai,https://www.bohumfit.ai,http://localhost:5173
# 로그인 토큰 검증용 — 프런트의 VITE_SUPABASE_* 와 동일한 값 (VITE_ 접두사만 제거)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# hCaptcha secret (선택). 설정 시 휴대폰 인증 요청의 X-HCaptcha-Token을 서버에서 검증합니다.
HCAPTCHA_SECRET=

# Frontend (Vercel)
VITE_API_URL=https://bohumfit.up.railway.app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SITE_URL=https://bohumfit.ai
# hCaptcha site key (선택). 설정 시 로그인·가입·휴대폰 인증 화면에 위젯을 표시합니다.
VITE_HCAPTCHA_SITEKEY=

# Sentry (선택, 비워두면 Sentry 비활성)
SENTRY_DSN=
VITE_SENTRY_DSN=

# 서비스 환경 (production | staging | development)
SERVICE_ENV=development
